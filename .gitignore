# ai_projects (docs/infra) - root repo ignore rules

# OS / tooling
Thumbs.db
Desktop.ini
.DS_Store

# Editors
.vscode/
.idea/

# Python
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.venv/
**/venv/

# Node / JS
**/node_modules/
**/.next/
**/dist/
**/build/

# Logs / outputs (generic)
**/*.log
**/output/
**/outputs/
**/downloads/
**/tmp/
**/.cache/

# IMPORTANT:
# `code/` contains separate git repos per project.
# We keep it readable for Cursor (context across docs/infra + code),
# but we still treat each subfolder as its own repo and do NOT commit it
# into this docs/infra root repo.

# Local scratch notes (do not commit by default)
/keep*.md
/keep.md
/hd_system_raw.md

# Local artifacts (examples, scratch)
/assets.jsonl

# Scratch staging area (LLM-inbox; never commit contents)
/scratch/**
!/scratch/README.md

# Secrets / tokens (never commit)
**/API_key_*.md


